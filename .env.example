# Copy this file to config.js and add your API key
# WARNING: Do NOT commit config.js to Git!
# 
# For Local Development:
# 1. Get a free API key from: https://openweathermap.org/api
# 2. Copy this file: cp .env.example config.js
# 3. Replace YOUR_API_KEY with your actual key
# 4. Add config.js to .gitignore (already done)
#
# For Vercel/Netlify Deployment:
# Set the environment variable OPENWEATHER_API_KEY in your deployment platform settings

OPENWEATHER_API_KEY=YOUR_API_KEY_HERE
